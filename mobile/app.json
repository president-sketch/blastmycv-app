{
  "expo": {
    "name": "BlastMyCV",
    "slug": "blastmycv",
    "scheme": "blastmycv",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blastmycv.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.blastmycv.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
